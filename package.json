{
  "name": "little-print",
  "version": "2.0.2",
  "description": "A wrapper for Nord Projects' Device Keys API for Little Printer",
  "keywords": [
    "berg",
    "device key",
    "little printer",
    "nord projects",
    "nord-sirius",
    "sirius",
    "thermal printer"
  ],
  "homepage": "https://github.com/banterability/little-print",
  "bugs": {
    "url": "https://github.com/banterability/little-print/issues"
  },
  "license": "MIT",
  "author": "Jeff Long <hello@banterability.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banterability/little-print.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "dist/index.d.ts",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=16"
  }
}
