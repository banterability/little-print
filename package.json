{
  "name": "little-print",
  "version": "2.0.2",
  "description": "A wrapper for Nord Projects' Device Keys API for Little Printer",
  "author": "Jeff Long <hello@banterability.com>",
  "license": "MIT",
  "exports": "./dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "26.1.1",
    "oxlint": "1.74.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "tsc",
    "fmt": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banterability/little-print.git"
  },
  "bugs": {
    "url": "https://github.com/banterability/little-print/issues"
  },
  "homepage": "https://github.com/banterability/little-print",
  "keywords": [
    "little printer",
    "thermal printer",
    "berg",
    "nord projects",
    "sirius",
    "nord-sirius",
    "device key"
  ],
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ]
}
